# PhishRadar Configuration

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
API_KEY=your-secure-api-key-here

# Threat Feed APIs (optional but recommended)
URLHAUS_AUTH_KEY=your-urlhaus-auth-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key
GOOGLE_SAFEBROWSING_API_KEY=your-google-safebrowsing-api-key
URLSCAN_API_KEY=your-urlscan-api-key
PHISHTANK_API_KEY=your-phishtank-api-key

# Reddit API (Optional - for threat feed monitoring)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=PhishRadar/1.0

# Database
DATABASE_URL=sqlite:///./phishradar.db

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Feed Update Interval (seconds)
FEED_UPDATE_INTERVAL=3600

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
